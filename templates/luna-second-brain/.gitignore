# Per-operator secrets
.env
.env.*
!.env.example

# Per-operator Obsidian state (workspace layout, hot-reload cache).
# Keep app.json / community-plugins.json / core-plugins.json / appearance.json
# checked in so a fresh clone inherits the vault's plugin set.
.obsidian/workspace*.json
.obsidian/cache/
.obsidian/hotkeys.json

# obsidian-local-rest-api stores apiKey + RSA private key + TLS cert in
# its data.json on first enable. NEVER commit — the plugin regenerates
# these on first enable per-operator, so each clone gets its own keys.
# (Other plugin data.json files stay tracked so fresh clones inherit
# usable defaults; they're audited free of credentials.)
.obsidian/plugins/obsidian-local-rest-api/data.json

# OS noise
.DS_Store
Thumbs.db

# Tooling caches
node_modules/
.venv/
__pycache__/
*.pyc

# Claude worktrees
/.claude/worktrees/
/.worktrees/
/.claude/settings.local.json

# Single-writer opt-in marker. A per-clone, gitignored file that designates
# THIS clone as committing/pushing straight to main by design (a personal,
# local-only vault). setup.{sh,ps1} create it for a local vault with no remote;
# the guardrail predicates (scripts/guardrails/lib.sh) honor it. A clone WITHOUT
# the marker stays protected by worktree-isolation, so it never travels via git.
.single-writer

# Handover scratch state
.last-consolidate.json

# Vault-template upgrade state (HIMMEL-389). The version stamp (.vault-template.json)
# IS tracked — it travels with the vault. These are upgrade-managed scratch:
# the 3-way-merge base snapshot, an unresolved _CLAUDE.md conflict sidecar, and
# any temp left by an interrupted atomic write.
.vault-template.base/
*.template-merge
*.upgrade-tmp.*
