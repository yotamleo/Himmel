      "title": "Luna sync",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "git rev-list --count @{u}..HEAD in the luna vault clone, no fetch (HIMMEL-1199). Omitted (no data) when the vault has no upstream configured. The exact signal for the incident this ticket detects: an auto-sync push silently blocked, commits piling up unpushed.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 19 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "luna_git_unpushed_commits", "legendFormat": "unpushed commits", "refId": "A" }
      ],
      "title": "Luna vault unpushed commits",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Line count of git status --porcelain in the luna vault clone (HIMMEL-1199) — catches a commit-gate block, complementing the push-gate signal above.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 19 },
      "id": 23,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "luna_git_uncommitted_files", "legendFormat": "uncommitted files", "refId": "A" }
      ],
      "title": "Luna vault uncommitted files",
      "type": "timeseries"
    },
