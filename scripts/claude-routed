#!/usr/bin/env bash
# claude-routed — thin launcher: Claude Code on the LOCAL loopback OmniRoute router.
# HIMMEL-654 WS2 (child HIMMEL-666). bash 3.2-safe. Copy-and-edit of scripts/claude-glm
# (WS1 extensibility seam): ONLY the backend block differs — loopback router base URL
# + an OmniRoute-issued client key. Everything else (guard, config-dir seeding, arg
# handling, exit codes) is behaviour-identical. Specs: WS1 wrapper
# himmel/specs/design/ws1-claude-glm-wrapper.md (the wrapper this edits); WS2 routed
# design himmel/specs/design/ws2-router-omniroute-pilot.md + plan
# himmel/specs/plan/ws2-router-omniroute-pilot.md (routed-specific rationale).
# shellcheck disable=SC1091  # load-dotenv.sh path issue
set -u

# --- backend block (DIFFERS from claude-glm; this is the whole variant) --------
# Host is FIXED to loopback (127.0.0.1) — the spec mandates loopback-only, so it is
# NOT configurable. Only the PORT is an env seam (OMNIROUTE_PORT); the operator-gated
# router deploy (Task 2) records the real chosen port. 20128 is the source-read
# documented default. The Z.ai key must NEVER appear here — the router terminates the
# provider keys itself, so this launcher carries only the OmniRoute CLIENT key.
ROUTED_BASE_URL="http://127.0.0.1:${OMNIROUTE_PORT:-20128}"
# Tier aliases are the SAME GLM values as claude-glm: the pilot lane is GLM-only
# intra-provider tiering and the router config defines these aliases.
# [1m] = Z.ai 1M-context variant (the routed pilot is GLM-only loopback, so [1m]
# passes through); ROUTED_CONTEXT_WINDOW feeds CLAUDE_CODE_AUTO_COMPACT_WINDOW (exec
# block below). Both overridable per task. HAIKU stays 4.7. If a future deployment
# routes to a non-GLM backend (codex ~277k, etc.), override both to match its window.
ROUTED_MODEL="${ROUTED_MODEL:-glm-5.2[1m]}"
ROUTED_HAIKU="glm-4.7"
ROUTED_CONTEXT_WINDOW="${ROUTED_CONTEXT_WINDOW:-1000000}"
CONFIG_DIR="${HOME}/.claude-routed"   # per-lane isolation (own seeded config dir)

HERE="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=lib/load-dotenv.sh
# Sourcing only DEFINES load_dotenv(); it must be CALLED with the key name.
# --root pins the .env to the LAUNCHER's repo (himmel), not the CWD repo —
# the motivating workload runs with cwd in the luna vault, whose .env has no
# OmniRoute key; CWD-resolution would exit 2 despite himmel/.env holding the key.
# CLAUDE_ROUTED_DOTENV_ROOT (test hook) overrides that root so hermetic tests
# never read the real himmel .env — same production code path either way.
if [ -z "${OMNIROUTE_API_KEY-}" ] && [ -f "$HERE/lib/load-dotenv.sh" ]; then
  . "$HERE/lib/load-dotenv.sh"
  load_dotenv --root "${CLAUDE_ROUTED_DOTENV_ROOT:-$HERE/..}" OMNIROUTE_API_KEY
  # load_dotenv leaves surrounding quotes literal (the shared lib does not strip
  # them); drop ONE matching surrounding quote pair so a `.env` value written as
  # OMNIROUTE_API_KEY="…" doesn't send the quotes to the API. bash 3.2-safe.
  case "${OMNIROUTE_API_KEY-}" in
    \"*\") OMNIROUTE_API_KEY="${OMNIROUTE_API_KEY#\"}"; OMNIROUTE_API_KEY="${OMNIROUTE_API_KEY%\"}" ;;
    \'*\') OMNIROUTE_API_KEY="${OMNIROUTE_API_KEY#\'}"; OMNIROUTE_API_KEY="${OMNIROUTE_API_KEY%\'}" ;;
  esac
fi

if [ -z "${OMNIROUTE_API_KEY-}" ]; then
  msg="claude-routed: OMNIROUTE_API_KEY is not set. Export it or add it to the repo .env (never settings.json)."
  [ -f "$HERE/lib/load-dotenv.sh" ] || msg="$msg (note: lib/load-dotenv.sh not found next to the launcher — .env was never read; run scripts/claude-routed from the himmel checkout rather than a copied/symlinked binary)"
  echo "$msg" >&2
  exit 2
fi

RESEED=0
FORCE=0
while [ $# -gt 0 ]; do
  case "$1" in
    --reseed) RESEED=1; shift ;;
    --force)  FORCE=1;  shift ;;
    *) break ;;
  esac
done

# Guard config dir is DELIBERATELY SHARED with claude-glm (~/.config/claude-glm),
# NOT a per-lane ~/.config/claude-routed: one guard source of truth means a PHI/
# egress rule written once governs every launcher variant. The routed lane is still
# GLM behind the router, so the exact same denylist/phi-roots policy applies.
CFG="${HOME}/.config/claude-glm"

path_under_any() { # $1 path, $2 listfile
  # returns: 0 = $1 is under a listed root; 1 = no restriction (absent list, or
  # present but no line matches); 2 = list exists but is not a readable regular
  # file (caller MUST fail closed — an unreadable guard config must never silently
  # allow egress).
  [ -e "$2" ] || return 1
  { [ -f "$2" ] && [ -r "$2" ]; } || return 2
  # `|| [ -n "$root" ]` keeps the last line when the file lacks a trailing newline
  # (POSIX read returns nonzero on an unterminated final line) — same idiom as
  # lib/load-dotenv.sh; without it a PHI root on the final line fails open.
  while IFS= read -r root || [ -n "$root" ]; do
    root="${root%$'\r'}"                   # strip trailing CR (CRLF config lines)
    root="${root%/}"                       # strip trailing slash
    # emptiness check AFTER normalization (matches the PS twin): a CR-only line
    # strips to "" and must be skipped, otherwise an empty root would form the
    # pattern "/*" and match every absolute path. NOTE: a deliberate lone "/"
    # root is likewise skipped — a block-everything root is not supported (also
    # twin-consistent with PS).
    [ -n "$root" ] || continue
    case "$1/" in "$root"/*) return 0 ;; esac
  done < "$2"
  return 1
}

CWD="$(pwd)"
path_under_any "$CWD" "$CFG/phi-roots"; phi_rc=$?
if [ "$phi_rc" -eq 2 ]; then
  echo "claude-routed: guard config $CFG/phi-roots exists but is not a readable file — failing closed." >&2
  exit 3
fi
if [ -f "$CWD/.salus" ] || [ "$phi_rc" -eq 0 ]; then
  echo "claude-routed: REFUSED - this workspace is PHI-marked (.salus / phi-roots). No override exists; PHI never goes to the routed GLM backend." >&2
  exit 3
fi
path_under_any "$CWD" "$CFG/egress-denylist"; deny_rc=$?
if [ "$deny_rc" -eq 2 ]; then
  echo "claude-routed: guard config $CFG/egress-denylist exists but is not a readable file — failing closed." >&2
  exit 3
fi
if [ "$deny_rc" -eq 0 ]; then
  if [ "$FORCE" -eq 1 ]; then
    echo "claude-routed: WARNING - denylisted workspace, proceeding under --force. Content WILL be sent through the local OmniRoute router." >&2
  else
    echo "claude-routed: REFUSED - workspace is on the egress denylist ($CFG/egress-denylist). Re-run with --force to override." >&2
    exit 3
  fi
fi

sanitize_settings() { # $1 src $2 dest — strip model + env.ANTHROPIC_* (node: himmel dep)
  node -e '
const fs=require("fs");
const j=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));
delete j.model;
if (j.env) for (const k of Object.keys(j.env)) if (k.indexOf("ANTHROPIC_")===0) delete j.env[k];
fs.writeFileSync(process.argv[2], JSON.stringify(j,null,2));
' "$1" "$2"
}

seed_fail() { # $1 = failing-operation detail — abort seeding, never mark it seeded
  echo "claude-routed: FAILED to $1. Refusing to launch with an unseeded config dir. Fix the cause and re-run (or rm -rf ~/.claude-routed)." >&2
  exit 4
}

seed_config_dir() {
  # Transactional: the .seeded sentinel is removed FIRST and (re)written LAST, so
  # ANY failure — first seed OR --reseed — leaves no sentinel and the next launch
  # re-seeds. Without the up-front delete a failed --reseed would exit 4 yet leave
  # a stale sentinel behind, and the next plain launch would proceed with the
  # half-populated tree.
  rm -f "$CONFIG_DIR/.seeded"
  SRC="${HOME}/.claude"
  mkdir -p "$CONFIG_DIR/plugins" || seed_fail "create $CONFIG_DIR/plugins"
  if [ -f "$SRC/settings.json" ]; then
    sanitize_settings "$SRC/settings.json" "$CONFIG_DIR/settings.json" \
      || seed_fail "sanitize settings.json (node missing/broken?)"
  else
    # True mirror (HIMMEL-819): a deleted source must not leave a stale copy
    # steering the lane — same rationale as the subtree re-mirror below.
    rm -f "$CONFIG_DIR/settings.json" || seed_fail "remove stale settings.json"
  fi
  # Leaf files mirror deletion too (HIMMEL-828/819): CLAUDE.md literally steers the lane,
  # so a deleted source must not leave a stale copy behind — same rationale as settings.
  for f in CLAUDE.md RTK.md; do
    if [ -f "$SRC/$f" ]; then
      cp "$SRC/$f" "$CONFIG_DIR/$f" || seed_fail "copy $f"
    else
      rm -f "$CONFIG_DIR/$f" || seed_fail "remove stale $f"
    fi
  done
  # Clean re-mirror + deletion mirror (HIMMEL-828/819, parity with the claude-glm twin):
  # rm the destination subtree FIRST — drops files deleted from the source, avoids BSD
  # cp -R nesting (commands/commands), AND mirrors a whole-subtree deletion so a removed
  # command/hook does not linger steering the routed lane ("a deleted source must not
  # leave a stale copy steering the lane") — then copy only when the source still exists.
  # No-op on the first seed; rm -rf on an absent dest is a safe no-op. Symmetric with the
  # settings/manifest mirror.
  for d in commands skills hooks agents; do
    rm -rf "${CONFIG_DIR:?}/$d" || seed_fail "clear stale $d"
    [ -d "$SRC/$d" ] && { cp -R "$SRC/$d" "$CONFIG_DIR/" || seed_fail "copy $d"; }
  done
  for p in installed_plugins.json known_marketplaces.json; do
    if [ -f "$SRC/plugins/$p" ]; then
      cp "$SRC/plugins/$p" "$CONFIG_DIR/plugins/$p" || seed_fail "copy plugins/$p"
    else
      rm -f "$CONFIG_DIR/plugins/$p" || seed_fail "remove stale plugins/$p"
    fi
  done
  rm -rf "${CONFIG_DIR:?}/plugins/marketplaces" || seed_fail "clear stale plugins/marketplaces"
  [ -d "$SRC/plugins/marketplaces" ] && { cp -R "$SRC/plugins/marketplaces" "$CONFIG_DIR/plugins/" || seed_fail "copy plugins/marketplaces"; }
  # claude-hud DISPLAY config — seed the single config.json only; the three cache
  # dirs under plugins/claude-hud/ (config-cache/context-cache/transcript-cache) are
  # runtime state, never seeded. Source-absent → mirror the deletion (HIMMEL-828/819).
  if [ -f "$SRC/plugins/claude-hud/config.json" ]; then
    mkdir -p "$CONFIG_DIR/plugins/claude-hud" || seed_fail "create $CONFIG_DIR/plugins/claude-hud"
    cp "$SRC/plugins/claude-hud/config.json" "$CONFIG_DIR/plugins/claude-hud/config.json" || seed_fail "copy plugins/claude-hud/config.json"
  else
    rm -f "$CONFIG_DIR/plugins/claude-hud/config.json" || seed_fail "remove stale plugins/claude-hud/config.json"
  fi
  : > "$CONFIG_DIR/.seeded" || seed_fail "write the .seeded sentinel"
}

# Staleness-aware reseed (HIMMEL-819): a once-only seed strands lane workers on
# whatever plugin/settings profile existed at first launch — the operator's lean
# enabledPlugins profile never reaches the lane, so every worker pays duplicated
# plugin context + duplicate MCP invocations. Track every allowlisted leaf source
# (settings, CLAUDE.md, RTK.md, the two plugin manifests, claude-hud config — newer
# than the sentinel OR deleted while a lane copy remains) AND the copied subtrees
# (HIMMEL-828 Part B — a half-seeded/externally-removed subtree, a top-level
# command/skill add/remove, or a deleted source, self-heals on plain launch); a deep
# in-file subtree edit still needs --reseed (directory mtime granularity).
# Opt-out: CLAUDE_LANE_AUTO_RESEED=0 restores the once-only seed (first seed +
# explicit --reseed only) — the escape hatch if auto-reseed ever blocks a
# launch in your setup (e.g. seed re-runs surfacing a broken node).
config_seed_stale() { # rc=0 when any tracked source is newer than the sentinel, or gone but still mirrored
  [ "${CLAUDE_LANE_AUTO_RESEED:-1}" = "0" ] && return 1
  for s in settings.json CLAUDE.md RTK.md plugins/installed_plugins.json plugins/known_marketplaces.json plugins/claude-hud/config.json; do
    if [ -f "${HOME}/.claude/$s" ]; then
      if [ "${HOME}/.claude/$s" -nt "$CONFIG_DIR/.seeded" ]; then return 0; fi
    elif [ -f "$CONFIG_DIR/$s" ]; then
      return 0  # source deleted but lane copy remains — reseed mirrors the removal
    fi
  done
  # HIMMEL-828 Part B — also track the copied subtrees, fully symmetric with the
  # settings/manifest loop above. Per subtree: SOURCE present but DEST missing = a
  # half-seed → reseed; SOURCE newer than the sentinel = top-level drift → reseed;
  # SOURCE absent but DEST present = a deleted source whose lane copy lingers → reseed
  # (the seeder mirrors the deletion, so this fires once then clears — no churn).
  for d in commands skills hooks agents plugins/marketplaces; do
    if [ -d "${HOME}/.claude/$d" ]; then
      [ -d "$CONFIG_DIR/$d" ] || return 0
      if [ "${HOME}/.claude/$d" -nt "$CONFIG_DIR/.seeded" ]; then return 0; fi
    elif [ -d "$CONFIG_DIR/$d" ]; then
      return 0  # source deleted but lane copy remains — reseed mirrors the removal
    fi
  done
  return 1
}

if [ ! -f "$CONFIG_DIR/.seeded" ] || [ "$RESEED" -eq 1 ] || config_seed_stale; then
  seed_config_dir
fi

# Peak window 14:00-18:00 UTC+8 == 06:00-10:00 UTC (unverified for the
# Anthropic-compatible endpoint - advisory only, spec Launch step 4). The routed
# lane is GLM behind the router, so the GLM peak-window advisory still applies.
HOUR_UTC=$(date -u +%H)
case "$HOUR_UTC" in
  06|07|08|09) echo "claude-routed: inside GLM peak window (14:00-18:00 UTC+8); off-peak resumes 10:00 UTC. Advisory only." >&2 ;;
  *)           echo "claude-routed: outside GLM peak window (14:00-18:00 UTC+8). Advisory only." >&2 ;;
esac

exec env \
  ANTHROPIC_BASE_URL="$ROUTED_BASE_URL" \
  ANTHROPIC_AUTH_TOKEN="$OMNIROUTE_API_KEY" \
  ANTHROPIC_MODEL="$ROUTED_MODEL" \
  ANTHROPIC_DEFAULT_HAIKU_MODEL="$ROUTED_HAIKU" \
  ANTHROPIC_DEFAULT_SONNET_MODEL="$ROUTED_MODEL" \
  ANTHROPIC_DEFAULT_OPUS_MODEL="$ROUTED_MODEL" \
  CLAUDE_CODE_AUTO_COMPACT_WINDOW="$ROUTED_CONTEXT_WINDOW" \
  CLAUDE_CONFIG_DIR="$CONFIG_DIR" \
  claude "$@"
