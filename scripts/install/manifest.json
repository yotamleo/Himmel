{
  "schemaVersion": 2,
  "harness": "claude",
  "items": [
    {
      "id": "pre-commit-hooks",
      "kind": "hook",
      "scopes": ["project"],
      "profiles": ["core", "all"],
      "deps": [],
      "probe": { "type": "file-exists", "path": ".pre-commit-config.yaml" },
      "removable": "full-offboard-only"
    },
    {
      "id": "wiring-pretooluse",
      "kind": "wiring",
      "scopes": ["project", "user"],
      "profiles": ["core", "all"],
      "deps": [],
      "probe": { "type": "settings-hooks", "file": ".claude/settings.json", "key": "hooks.PreToolUse" },
      "install": { "type": "wire", "target": "pretooluse-hooks" },
      "unwire": { "type": "wire", "target": "pretooluse-hooks" },
      "removable": "per-item"
    },
    {
      "id": "wiring-statusline",
      "kind": "wiring",
      "scopes": ["project", "user"],
      "profiles": ["core", "all"],
      "deps": [],
      "probe": { "type": "settings-key", "file": ".claude/settings.json", "key": "statusLine.command" },
      "install": { "type": "wire", "target": "statusline" },
      "unwire": { "type": "wire", "target": "statusline" },
      "removable": "per-item"
    },
    {
      "id": "jira-cli-dist-build",
      "kind": "dep",
      "scopes": ["project"],
      "profiles": ["core", "all"],
      "deps": [],
      "probe": { "type": "file-exists", "path": "scripts/jira/dist/index.js" },
      "install": { "type": "build", "target": "jira-cli" },
      "removable": "full-offboard-only"
    },
    {
      "id": "jira-env-keys",
      "kind": "dep",
      "scopes": ["project", "user"],
      "profiles": ["core", "all"],
      "deps": [],
      "probe": { "type": "settings-key", "file": ".env", "keys": ["JIRA_BASE_URL", "JIRA_EMAIL", "JIRA_API_TOKEN", "JIRA_PROJECT_KEY"] },
      "install": { "type": "config", "keys": ["JIRA_BASE_URL", "JIRA_EMAIL", "JIRA_API_TOKEN", "JIRA_PROJECT_KEY"] },
      "removable": "full-offboard-only"
    },
    {
      "id": "bitbucket-cli-build",
      "kind": "dep",
      "scopes": ["project"],
      "profiles": ["core", "all"],
      "deps": [],
      "probe": { "type": "file-exists", "path": "scripts/bitbucket/dist/index.js" },
      "install": { "type": "build", "target": "bitbucket-cli" },
      "removable": "full-offboard-only"
    },
    {
      "id": "qmd-binary",
      "kind": "dep",
      "scopes": ["project", "user"],
      "profiles": ["luna", "all"],
      "deps": [],
      "probe": { "type": "cmd:has_qmd", "resolver": "scripts/lib/qmd-bin.sh" },
      "install": { "type": "qmd" },
      "removable": "full-offboard-only",
      "offboard": "advise"
    },
    {
      "id": "qmd-index",
      "kind": "vault",
      "scopes": ["project", "user"],
      "profiles": ["luna", "all"],
      "deps": ["qmd-binary"],
      "probe": { "type": "qmd-index", "collections": ["himmel", "luna"] },
      "install": { "type": "qmd" },
      "removable": "full-offboard-only"
    },
    {
      "id": "tokensave-binary",
      "kind": "dep",
      "scopes": ["project", "user"],
      "profiles": ["luna", "all"],
      "deps": [],
      "probe": { "type": "dep", "cmd": "tokensave" },
      "removable": "full-offboard-only",
      "offboard": "advise"
    },
    {
      "id": "tokensave-mcp",
      "kind": "mcp",
      "scopes": ["project", "user"],
      "profiles": ["luna", "all"],
      "deps": ["tokensave-binary"],
      "probe": { "type": "mcp-registered", "server": "tokensave" },
      "removable": "full-offboard-only"
    },
    {
      "id": "graphify-mcp",
      "kind": "mcp",
      "scopes": ["project", "user"],
