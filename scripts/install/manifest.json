      "kind": "vault",
      "scopes": ["user"],
      "profiles": ["luna", "all"],
      "deps": [],
      "probe": { "type": "file-exists", "path": "{vaultPath}/.vault-template.json" },
      "install": { "type": "adopt" },
      "removable": "full-offboard-only",
      "offboard": "keep"
    },
    {
      "id": "claude-plugins-pluginSet",
      "kind": "plugin",
      "scopes": ["project", "user"],
      "profiles": ["core", "luna", "all"],
      "deps": [],
